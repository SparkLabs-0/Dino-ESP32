// ============================================================
// Dino ESP - T-Rex style runner game for ESP32
// ============================================================
#include <Arduino.h>
#include <U8g2lib.h>
#include <Wire.h>

// ============================================================
// HARDWARE PINS
// ============================================================

#define BUTTON_PIN  5
#define BUZZER_PIN  10

// ============================================================
// DISPLAY
// ============================================================

U8G2_SSD1306_128X64_NONAME_F_HW_I2C display(U8G2_R0, U8X8_PIN_NONE);

// ============================================================
// GAME CONFIGURATION
// ============================================================

// Timing
#define DEBOUNCE_DELAY  180

// Layout
#define DINO_BASE_Y     38
#define GROUND_Y        60

// Jump physics
#define JUMP_HEIGHT     40
#define JUMP_SPEED      4

// Ground detail
#define NUM_TUFTS       6
#define NUM_PEBBLES     8

// Sound frequencies
#define FREQ_JUMP       900
#define FREQ_SCORE_LO   1200
#define FREQ_SCORE_HI   1500
#define FREQ_DEATH_HI   400
#define FREQ_DEATH_LO   200

// Game states
#define GAME_START      0
#define GAME_OVER       1
#define GAME_PLAYING    2

volatile int gameState = GAME_START;

